# Foundation API base URL. Local dev defaults match the niov-foundation
# package. Production deploys override via the hosting platform's env
# config (and the Docker build arg of the same name — baked at build time,
# since a Vite SPA cannot read env vars at runtime in the browser).
VITE_FOUNDATION_API_URL=http://localhost:3000/api/v1

# [OTZAR-V1-LIVE-1B] Set to "true" to reveal placeholder ("coming soon") admin
# nav entries (Analytics, Conversations, Workflows, Playground, Settings,
# Documentation, Intelligence). Hidden by default so v1 validation never lands
# on a reserved/stub screen. Their routes stay registered regardless.
VITE_SHOW_COMING_SOON=false
